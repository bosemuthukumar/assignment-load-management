{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "backend/src/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/routes/(.*)", "dest": "/backend/src/$1.js" },
    {
      "src": "/(.*)",
      "dest": "/frontend/build/index.html"
    }
  ]
}
